{% extends "layouts/base.html" %}

{% block title %}Admins{% endblock %}

{% block content %}
<style>
    .admin-status-badge {
        border-radius: 999px;
        padding: 0.35rem 0.75rem;
        font-size: 0.76rem;
        font-weight: 900;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .admin-status-badge.is-active {
        color: #86efac;
        background: rgba(34, 197, 94, 0.13);
        border-color: rgba(34, 197, 94, 0.45);
    }

    .admin-status-badge.is-inactive {
        color: #cbd5e1;
        background: rgba(148, 163, 184, 0.12);
        border-color: rgba(148, 163, 184, 0.32);
    }

    .admin-actions-cell {
        min-width: 260px;
    }

    .admin-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        justify-content: flex-start;
    }

    .admin-actions .btn {
        min-width: 110px;
        white-space: nowrap;
    }

    .admin-actions form {
        margin: 0;
    }

    .admin-action-btn {
        border-radius: 0.65rem;
        font-weight: 800;
        border: 1px solid transparent;
        transition: 0.16s ease;
    }

    .admin-action-btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.08);
    }

    .admin-edit-btn {
        color: #ffffff;
        background: #2563eb;
        border-color: rgba(37, 99, 235, 0.7);
    }

    .admin-reset-btn {
        color: #111827;
        background: #f59e0b;
        border-color: rgba(245, 158, 11, 0.75);
    }

    .admin-deactivate-btn {
        color: #ffffff;
        background: #dc2626;
        border-color: rgba(220, 38, 38, 0.75);
    }

    .admin-activate-btn {
        color: #ffffff;
        background: #16a34a;
        border-color: rgba(22, 163, 74, 0.75);
    }

    .admin-action-btn {
        border-radius: 0.65rem;
        font-weight: 800;
        border: 1px solid transparent;
        transition: 0.16s ease;
    }

    .admin-action-btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.08);
    }

    .admin-edit-btn {
        color: #ffffff;
        background: #2563eb;
        border-color: rgba(37, 99, 235, 0.7);
    }

    .admin-reset-btn {
        color: #111827;
        background: #f59e0b;
        border-color: rgba(245, 158, 11, 0.75);
    }

    .admin-deactivate-btn {
        color: #ffffff;
        background: #dc2626;
        border-color: rgba(220, 38, 38, 0.75);
    }

    .admin-activate-btn {
        color: #ffffff;
        background: #16a34a;
        border-color: rgba(22, 163, 74, 0.75);
    }
</style>

{% set title = "Admins" %}
{% set action_url = url_for('admins.new_admin') %}
{% set action_label = "Add Admin" %}
{% include "layouts/partials/_page_header.html" %}

<div class="card hover-lift">
    <div class="table-responsive">
        <table class="table table-vcenter card-table table-striped table-hover">
            <thead>
                <tr>
                    <th>Admin ID</th>
                    <th>Full Name</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Last Login</th>
                    <th class="admin-actions-cell">Actions</th>
                </tr>
            </thead>

            <tbody>
                {% for admin in admins %}
                <tr>
                    <td class="fw-bold">{{ admin.AdminCode }}</td>
                    <td>{{ admin.FullName }}</td>
                    <td>{{ admin.UserName }}</td>
                    <td>{{ admin.Email or '—' }}</td>
                    <td>
                        <span class="admin-status-badge {% if admin.IsActive %}is-active{% else %}is-inactive{% endif %}">
                            {{ 'Active' if admin.IsActive else 'Inactive' }}
                        </span>
                    </td>
                    <td>{{ admin.LastLoginDate or 'Never' }}</td>
                    <td class="admin-actions-cell">
                        <div class="admin-actions">
                            <a href="{{ url_for('admins.edit_admin', admin_id=admin.AdminUserID) }}" class="btn btn-sm btn-action admin-action-btn admin-edit-btn">
                                Edit
                            </a>

                            <a href="{{ url_for('admins.reset_password', admin_id=admin.AdminUserID) }}" class="btn btn-sm btn-action admin-action-btn admin-reset-btn">
                                Reset Password
                            </a>

                            <form method="post" action="{{ url_for('admins.toggle_admin', admin_id=admin.AdminUserID) }}" class="d-inline">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                                <button type="submit" class="btn btn-sm btn-action admin-action-btn {% if admin.IsActive %}admin-deactivate-btn{% else %}admin-activate-btn{% endif %}">
                                    {{ 'Deactivate' if admin.IsActive else 'Activate' }}
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center text-secondary py-4">
                        No admins found.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
