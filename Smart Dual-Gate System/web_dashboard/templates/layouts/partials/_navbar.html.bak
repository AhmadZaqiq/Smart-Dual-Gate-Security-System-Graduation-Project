<header class="navbar navbar-expand-md d-print-none top-navbar-premium">
    <div class="container-xl">
        <div class="navbar-nav flex-row flex-wrap align-items-center gap-2 me-auto d-none d-xl-flex">
            <span class="status-pill" id="nav-process-badge" data-state="UNKNOWN"><i class="ti ti-cpu me-1"></i><span>Process: --</span></span>
            <span class="status-pill" id="nav-workflow-badge" data-state="UNKNOWN"><i class="ti ti-route me-1"></i><span>Workflow: --</span></span>
            <span class="status-pill" id="nav-count-badge" data-state="NORMAL"><i class="ti ti-users me-1"></i><span>Persons: 0</span></span>
            <span class="status-pill" id="nav-stream-badge" data-state="INACTIVE"><i class="ti ti-video me-1"></i><span>Stream: --</span></span>
            <span class="status-pill" id="nav-alarm-badge" data-state="NORMAL"><i class="ti ti-bell me-1"></i><span>Alarm: Normal</span></span>
        </div>

        <div class="navbar-nav flex-row order-md-last ms-auto align-items-center gap-2">
            <div class="btn-list d-none d-md-flex">
                <button type="button" class="btn btn-sm btn-success system-control-btn" data-action="start" title="Start System"><i class="ti ti-player-play"></i></button>
                <button type="button" class="btn btn-sm btn-danger system-control-btn" data-action="stop" title="Stop System"><i class="ti ti-player-stop"></i></button>
                <button type="button" class="btn btn-sm btn-warning system-control-btn" data-action="restart" title="Restart System"><i class="ti ti-refresh"></i></button>
            </div>

            <div class="nav-item dropdown">
                <a href="#" class="nav-link px-2" data-bs-toggle="dropdown" aria-label="Notifications">
                    <i class="ti ti-bell"></i>
                </a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-card">
                    <div class="card">
                        <div class="card-header"><h3 class="card-title">Notifications</h3></div>
                        <div class="list-group list-group-flush">
                            <div class="list-group-item text-secondary small">Security alerts will appear here.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="nav-item dropdown">
                <a href="#" class="nav-link d-flex lh-1 p-0 px-2" data-bs-toggle="dropdown">
                    <span class="avatar avatar-sm admin-avatar">{{ admin_profile().initials }}</span>
                    <div class="d-none d-xl-block ps-2 text-start">
                        <div class="fw-semibold text-white">{{ admin_profile().display_name }}</div>
                        <div class="small text-secondary">{{ admin_profile().role_label }}</div>
                    </div>
                </a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                    <div class="dropdown-header">{{ admin_profile().display_name }}</div>
                    <div class="dropdown-item-text text-secondary small">@{{ admin_profile().username }}</div>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item text-danger" href="{{ url_for('auth.logout') }}"><i class="ti ti-logout me-2"></i>Logout</a>
                </div>
            </div>
        </div>
    </div>
</header>
