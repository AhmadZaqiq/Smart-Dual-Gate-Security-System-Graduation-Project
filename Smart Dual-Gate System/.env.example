# Flask dashboard configuration
FLASK_SECRET_KEY=replace-with-a-long-random-secret-key

# Dashboard server
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Paths
DATABASE_PATH=database/mantrap.db
STATUS_FILE_PATH=runtime/mantrap_status.json
SYSTEM_LOG_PATH=logs/system.log

# YOLO MJPEG stream
YOLO_STREAM_BASE_URL=http://127.0.0.1:5000

# Runtime status staleness threshold
STATUS_STALE_SECONDS=15
STREAM_HEALTH_TIMEOUT=2.0

# Session
PERMANENT_SESSION_LIFETIME_HOURS=12
SESSION_COOKIE_SECURE=0

# Email alert configuration
# Use a Gmail App Password, not your normal Gmail password.
ALERT_EMAIL_ADDRESS=your_email@gmail.com
ALERT_EMAIL_APP_PASSWORD=your_16_digit_app_password
DASHBOARD_PUBLIC_URL=http://your-raspberry-pi-ip:8000
