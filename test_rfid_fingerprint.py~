import time
import subprocess
import RPi.GPIO as GPIO
from mfrc522 import MFRC522
from pyfingerprint.pyfingerprint import PyFingerprint

AUTHORIZED_RFID = [682511166205, 151122205133]
FINGER_PORT = "/dev/serial0"
FINGER_BAUD = 57600


def reset_uart():
    print("\n[RESET] Resetting UART...")
    subprocess.run(["sudo", "fuser", "-k", FINGER_PORT], stderr=subprocess.DEVNULL)
    time.sleep(1)


def test_rfid(timeout=10):
    print("\n[RFID] Put card near reader...")

    GPIO.setwarnings(False)
    GPIO.setmode(GPIO.BCM)

    reader = MFRC522()
    start = time.time()

    while time.time() - start < timeout:
        status, _ = reader.MFRC522_Request(reader.PICC_REQIDL)

        if status == reader.MI_OK:
            status, uid = reader.MFRC522_Anticoll()

            if status == reader.MI_OK:
                card_id = int("".join(str(x) for x in uid))
                print(f"[RFID] Detected ID: {card_id}")

                if card_id in AUTHORIZED_RFID:
                    print("[RFID] Accepted")
                    return True
                else:
                    print("[RFID] Rejected")
                    return False

        time.sleep(0.1)

    print("[RFID] Timeout")
    return False


def test_fingerprint():
    print("\n[FINGER] Starting fingerprint test...")

    try:
        finger = PyFingerprint(FINGER_PORT, FINGER_BAUD, 0xFFFFFFFF, 0x00000000)

        if not finger.verifyPassword():
            print("[FINGER] Sensor password wrong")
            return False

        print("[FINGER] Sensor ready")
        print("[FINGER] Put finger on sensor...")

        start = time.time()
        while not finger.readImage():
            if time.time() - start > 10:
                print("[FINGER] Timeout")
                return False
            time.sleep(0.2)

        finger.convertImage(0x01)
        result = finger.searchTemplate()

        position = result[0]
        accuracy = result[1]

        if position >= 0:
            print(f"[FINGER] Accepted at position {position}, accuracy {accuracy}")
            return True
        else:
            print("[FINGER] Not recognized")
            return False

    except Exception as e:
        print(f"[FINGER] ERROR: {e}")
        return False


try:
    print("=== RFID + Fingerprint Coexistence Test ===")

    rfid_ok = test_rfid()

    print("\n[INFO] Waiting before fingerprint...")
    time.sleep(2)

    reset_uart()

    finger_ok = test_fingerprint()

    print("\n=== RESULT ===")
    print(f"RFID: {rfid_ok}")
    print(f"Fingerprint: {finger_ok}")

except KeyboardInterrupt:
    print("\nStopped by user")

finally:
    GPIO.cleanup()
    print("GPIO cleaned")
